{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/sterling-crest/dist/public",
  "framework": "vite",
  "regions": ["iad1"],
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "artifacts/api-server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ],
  "env": {
    "DATABASE_URL": "postgresql://neondb_owner:npg_XoxseEaHW05Z@ep-young-cake-a4u9tmqd-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require",
    "SESSION_SECRET": "@session_secret",
    "NODE_ENV": "production"
  }
}
