{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/sterling-crest/dist/public",
  "framework": "vite",
  "regions": ["iad1"],
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs@20",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": ["artifacts/api-server/**", "lib/db/**", "lib/api-zod/**"]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ]
}
