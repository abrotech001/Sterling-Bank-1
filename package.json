{
  "name": "workspace",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs && node -e \"require('fs').copyFileSync('node_modules/tiny-secp256k1/lib/secp256k1.wasm', 'dist/secp256k1.wasm')\"",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@vercel/node": "^5.7.13",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
